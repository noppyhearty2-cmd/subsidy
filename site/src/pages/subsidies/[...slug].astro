  ina_machi: "伊奈町", miyoshi_machi: "三芳町", moroyama: "毛呂山町", ogose: "越生町",
  namegawa: "滑川町", ranzan: "嵐山町", ogawa_s: "小川町", kawashima_s: "川島町",
  yoshimi: "吉見町", hatoyama: "鳩山町", tokigawa: "ときがわ町", yokoze: "横瀬町",
  minano: "皆野町", nagatoro: "長瀞町", ogano: "小鹿野町", higashichichibu: "東秩父村",
  misato_machi: "美里町", kamikawa_s: "神川町", kamisato: "上里町", yorii: "寄居町",
  miyashiro: "宮代町", sugito: "杉戸町", matsubushi: "松伏町",
  // 兵庫県
  hyogo_pref: "兵庫県",
  kobe: "神戸市", himeji: "姫路市", amagasaki: "尼崎市", akashi: "明石市",
  nishinomiya: "西宮市", sumoto: "洲本市", ashiya: "芦屋市", itami: "伊丹市",
  aioi: "相生市", toyooka: "豊岡市", kakogawa: "加古川市", ako: "赤穂市",
  nishiwaki: "西脇市", takarazuka: "宝塚市", miki: "三木市", takasago: "高砂市",
  kawanishi: "川西市", ono_hyogo: "小野市", sanda: "三田市", kasai: "加西市",
  tanbasasayama: "丹波篠山市", yabu: "養父市", tanba: "丹波市",
  minamiawaji: "南あわじ市", asago: "朝来市", awaji: "淡路市", shiso: "宍粟市",
  kato: "加東市", tatsuno: "たつの市",
  inagawa: "猪名川町", taka_machi: "多可町", inami_hyogo: "稲美町", harima: "播磨町",
  ichikawa_h: "市川町", fukusaki: "福崎町", kamikawa_h: "神河町", taishi_h: "太子町",
  kamigori: "上郡町", sayo: "佐用町", mikata_h: "香美町", shinonsen: "新温泉町",
  // 滋賀県
  shiga_pref: "滋賀県",
  otsu: "大津市", hikone: "彦根市", nagahama: "長浜市", omihachiman: "近江八幡市",
  kusatsu: "草津市", moriyama_shiga: "守山市", ritto: "栗東市", koka: "甲賀市",
  yasu: "野洲市", konan_shiga: "湖南市", takashima: "高島市", higashiomi: "東近江市", maibara: "米原市",
  hino_shiga: "日野町", ryuou: "竜王町", aisho: "愛荘町", toyosato: "豊郷町", kora: "甲良町", taga: "多賀町",
  // 奈良県
  nara_pref: "奈良県",
  nara: "奈良市", yamatotakada: "大和高田市", yamatokoriyama: "大和郡山市", tenri: "天理市",
  kashihara: "橿原市", sakurai_nara: "桜井市", gojo: "五條市", gose: "御所市",
  ikoma: "生駒市", kashiba: "香芝市", katsuragi: "葛城市", uda: "宇陀市",
  ikaruga: "斑鳩町", tawaramoto: "田原本町", koryo: "広陵町",
  yoshino_nara: "吉野町", totsukawa: "十津川村", tenkawa: "天川村",
};
const muniName = muniLabel[d.municipality] ?? d.municipality;
const prefName = muniToPref[d.municipality] ?? null;
// 都道府県レベルの記事（osaka_pref 等）は自治体リンクを省略
const showMuniCrumb = prefName !== null && muniName !== prefName;

const siteOrigin = "https://noppyhearty2-cmd.github.io";
const basePath   = "/subsidy";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.title}</title>
    <meta name="description" content={d.summary_ja || d.title} />
    <link rel="canonical" href={`${siteOrigin}${basePath}/subsidies/${entry.slug}/`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "補助金まとめ",
          "item": `${siteOrigin}${basePath}/` },
        ...(prefName ? [{ "@type": "ListItem", "position": 2, "name": prefName,
          "item": `${siteOrigin}${basePath}/?pref=${encodeURIComponent(prefName)}` }] : []),
        ...(showMuniCrumb ? [{ "@type": "ListItem", "position": 3, "name": muniName,
          "item": `${siteOrigin}${basePath}/?muni=${d.municipality}` }] : []),
        { "@type": "ListItem",
          "position": prefName ? (showMuniCrumb ? 4 : 3) : 2,
          "name": d.title,
          "item": `${siteOrigin}${basePath}/subsidies/${entry.slug}/` },
      ]
    })} />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CNL0G50ECB"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CNL0G50ECB');
    </script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: "Hiragino Sans", "Meiryo", sans-serif; background: #f0f4f8; color: #333; line-height: 1.8; }

      /* ヘッダー・パンくず */
      header { background: #1a5276; color: white; padding: 0.6rem 1rem; }
      .breadcrumb { display: flex; align-items: center; flex-wrap: wrap; gap: 0.25rem; font-size: 0.85rem; }
      .breadcrumb a { color: #aed6f1; text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; color: white; }
      .breadcrumb .sep { color: rgba(255,255,255,0.45); margin: 0 0.1rem; }
      .breadcrumb .current { color: rgba(255,255,255,0.75); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 240px; }

      .container { max-width: 800px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

      /* タイトルカード */
      .title-card {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        border-top: 4px solid #1a5276;
      }
      .title-card h1 { font-size: 1.25rem; line-height: 1.6; color: #1a2e3b; margin-bottom: 0.75rem; }
      .title-card .summary { font-size: 0.92rem; color: #555; background: #f8f9fa; border-left: 3px solid #1a5276; padding: 0.6rem 0.8rem; border-radius: 0 4px 4px 0; }

      /* サマリーテーブル */
      .summary-table {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
      }
      .summary-table table { width: 100%; border-collapse: collapse; }
      .summary-table th {
        background: #eaf0f7;
        color: #1a5276;
        font-size: 0.82rem;
        font-weight: 600;
        width: 110px;
        padding: 0.7rem 1rem;
        border-bottom: 1px solid #dce6f0;
        vertical-align: top;
        text-align: left;
      }
      .summary-table td {
        padding: 0.7rem 1rem;
        font-size: 0.92rem;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: top;
      }
      .summary-table tr:last-child th,
      .summary-table tr:last-child td { border-bottom: none; }
      .amount-val { color: #1e8449; font-weight: 700; font-size: 1rem; }
      .deadline-val { color: #c0392b; font-weight: 700; }
      .badge { display: inline-block; padding: 0.15rem 0.55rem; border-radius: 20px; background: #e8f0fe; color: #1a5276; font-size: 0.75rem; margin: 0.1rem 0.2rem 0.1rem 0; }

      /* ポイントカード */
      .points-card {
        background: #fffbea;
        border: 1px solid #f5d87a;
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
      }
      .points-card h2 { font-size: 0.88rem; color: #7d6608; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; }
      .points-card ol { list-style: none; counter-reset: point; padding: 0; }
      .points-card li { counter-increment: point; display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 0.5rem; font-size: 0.9rem; }
      .points-card li::before {
        content: counter(point);
        background: #1a5276;
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        min-width: 1.4rem;
        height: 1.4rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 0.1rem;
      }

      /* 記事本文 */
      .article {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
      }
      /* 記事本文ラベル */
      .article-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: #1a5276;
        border-bottom: 2px solid #eaf0f7;
        padding-bottom: 0.6rem;
        margin-bottom: 1rem;
        letter-spacing: 0.03em;
      }

      /* Markdownレンダリング要素は :global() で指定 */
      .article :global(h1) { display: none; }
      .article :global(h2) {
        font-size: 0.9rem;
        font-weight: 700;
        margin: 1.5rem 0 0.6rem;
        padding: 0.4rem 0.75rem;
        background: #eaf0f7;
        border-left: 4px solid #1a5276;
        border-radius: 0 4px 4px 0;
        color: #1a2e3b;
      }
      .article :global(h2:first-child) { margin-top: 0; }
      .article :global(h3) { font-size: 0.85rem; margin: 1rem 0 0.4rem; color: #1a5276; }
      .article :global(p) { margin-bottom: 0.75rem; font-size: 0.85rem; }
      .article :global(ul), .article :global(ol) { padding-left: 1.4rem; margin-bottom: 0.75rem; font-size: 0.85rem; }
      .article :global(li) { margin-bottom: 0.3rem; }
      .article :global(strong) { color: #1a2e3b; }
      .article :global(blockquote) {
        border-left: 3px solid #aaa;
        padding: 0.6rem 1rem;
        color: #666;
        font-size: 0.85rem;
        margin: 1rem 0;
        background: #f8f9fa;
        border-radius: 0 4px 4px 0;
      }
      .article :global(a) { color: #1a5276; word-break: break-all; }

      /* テーブル */
      .article :global(table) { width: 100%; border-collapse: collapse; margin: 0.75rem 0 1rem; font-size: 0.85rem; }
      .article :global(th) { background: #eaf0f7; color: #1a5276; padding: 0.5rem 0.75rem; border: 1px solid #d0dce8; font-weight: 600; text-align: left; }
      .article :global(td) { padding: 0.5rem 0.75rem; border: 1px solid #e8e8e8; }
      .article :global(tr:nth-child(even) td) { background: #fafafa; }

      footer { text-align: center; padding: 2rem; font-size: 0.8rem; color: #999; }
    </style>
  </head>
  <body>
    <header>
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/subsidy/">補助金まとめ</a>
        {prefName && (
          <>
            <span class="sep" aria-hidden="true">›</span>
            <a href={`/subsidy/?pref=${encodeURIComponent(prefName)}`}>{prefName}</a>
          </>
        )}
        {showMuniCrumb && (
          <>
            <span class="sep" aria-hidden="true">›</span>
            <a href={`/subsidy/?muni=${d.municipality}`}>{muniName}</a>
          </>
        )}
        <span class="sep" aria-hidden="true">›</span>
        <span class="current">{d.title}</span>
      </nav>
    </header>

    <div class="container">

      <!-- タイトル＋概要 -->
      <div class="title-card">
        <h1>{d.title}</h1>
        {d.summary_ja && <p class="summary">{d.summary_ja}</p>}
      </div>

      <!-- サマリーテーブル -->
      <div class="summary-table">
        <table>
          <tbody>
            <tr>
              <th>対象者</th>
              <td>{d.target}</td>
            </tr>
            {d.amount && (
              <tr>
                <th>補助金額</th>
                <td><span class="amount-val">{d.amount}</span></td>
              </tr>
            )}
            <tr>
              <th>申込期限</th>
              <td>
                {d.deadline && d.deadline !== "随時"
                  ? <span class="deadline-val">{d.deadline}</span>
                  : "随時受付"}
              </td>
            </tr>
            <tr>
              <th>カテゴリ</th>
              <td>{d.tags.map((t) => <span class="badge">{t}</span>)}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- 申請ポイント -->
      {d.key_points && d.key_points.length > 0 && (
        <div class="points-card">
          <h2>⚡ 申請前に確認！重要ポイント</h2>
          <ol>
            {d.key_points.map((p) => <li>{p}</li>)}
          </ol>
        </div>
      )}

      <!-- 記事本文 -->
      <article class="article">
        <div class="article-label">📄 詳細説明</div>
        <Content />
      </article>
    </div>

    <footer>
      本サイトの情報は自動収集・AI要約によるものです。必ず公式ページをご確認ください。
    </footer>
  </body>
</html>
