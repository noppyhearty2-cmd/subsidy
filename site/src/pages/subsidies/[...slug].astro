---
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("subsidies");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"subsidies">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.title}</title>
    <meta name="description" content={d.summary_ja || d.title} />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: "Hiragino Sans", "Meiryo", sans-serif; background: #f8f9fa; color: #333; line-height: 1.7; }
      header { background: #1a5276; color: white; padding: 1rem; }
      header a { color: #aed6f1; text-decoration: none; font-size: 0.9rem; }
      .container { max-width: 760px; margin: 0 auto; padding: 1.5rem 1rem; }
      .info-box { background: white; border-radius: 8px; padding: 1.25rem; margin-bottom: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
      .info-box h2 { font-size: 0.85rem; color: #666; margin-bottom: 0.75rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem; }
      .info-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; font-size: 0.9rem; align-items: flex-start; }
      .info-label { color: #666; min-width: 80px; flex-shrink: 0; }
      .info-val { font-weight: 500; }
      .info-val.amount { color: #27ae60; }
      .info-val.deadline { color: #c0392b; }
      .badge { padding: 0.15rem 0.5rem; border-radius: 4px; background: #e8f0fe; color: #1a5276; font-size: 0.75rem; }
      .article { background: white; border-radius: 8px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
      .article h1 { font-size: 1.2rem; margin-bottom: 1rem; line-height: 1.5; }
      .article h2 { font-size: 1rem; margin: 1.25rem 0 0.5rem; padding-left: 0.5rem; border-left: 3px solid #1a5276; }
      .article p { margin-bottom: 0.75rem; font-size: 0.95rem; }
      .article ul, .article ol { padding-left: 1.25rem; margin-bottom: 0.75rem; font-size: 0.95rem; }
      .article li { margin-bottom: 0.25rem; }
      .article blockquote { border-left: 3px solid #ccc; padding-left: 1rem; color: #666; font-size: 0.9rem; margin: 1rem 0; }
      .article a { color: #1a5276; }
      footer { text-align: center; padding: 2rem; font-size: 0.8rem; color: #999; }
    </style>
  </head>
  <body>
    <header>
      <a href={import.meta.env.BASE_URL}>← 一覧に戻る</a>
    </header>

    <div class="container">
      <div class="info-box">
        <h2>基本情報</h2>
        <div class="info-row">
          <span class="info-label">対象者</span>
          <span class="info-val">{d.target}</span>
        </div>
        {d.amount && (
          <div class="info-row">
            <span class="info-label">金額</span>
            <span class="info-val amount">{d.amount}</span>
          </div>
        )}
        {d.deadline && (
          <div class="info-row">
            <span class="info-label">申込期限</span>
            <span class="info-val deadline">{d.deadline}</span>
          </div>
        )}
        <div class="info-row">
          <span class="info-label">カテゴリ</span>
          <span class="info-val" style="display:flex;flex-wrap:wrap;gap:0.3rem;">
            {d.tags.map((t) => <span class="badge">{t}</span>)}
          </span>
        </div>
      </div>

      <article class="article">
        <Content />
      </article>
    </div>

    <footer>
      本サイトの情報は自動収集・AI要約によるものです。必ず公式ページをご確認ください。
    </footer>
  </body>
</html>
