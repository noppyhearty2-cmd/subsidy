---
import { getCollection } from "astro:content";

const allSubsidies = await getCollection("subsidies");
const active = allSubsidies
  .filter((s) => s.data.is_active)
  .sort((a, b) => {
    if (!a.data.deadline) return 1;
    if (!b.data.deadline) return -1;
    return a.data.deadline.localeCompare(b.data.deadline);
  });

const allTags = [...new Set(active.flatMap((s) => s.data.tags))].sort();

// 自治体IDから表示名へのマッピング
const muniLabel: Record<string, string> = {
  osaka: "大阪市",
  osaka_pref: "大阪府",
  suita: "吹田市",
  toyonaka: "豊中市",
  sakai: "堺市",
  higashiosaka: "東大阪市",
  hirakata: "枚方市",
  takatsuki: "高槻市",
  ibaraki: "茨木市",
  yao: "八尾市",
  neyagawa: "寝屋川市",
  moriguchi: "守口市",
  kadoma: "門真市",
  daito: "大東市",
  shijonawate: "四條畷市",
  katano: "交野市",
  kashiwara: "柏原市",
  matsubara: "松原市",
  habikino: "羽曳野市",
  fujiidera: "藤井寺市",
  kawachinagano: "河内長野市",
  tondabayashi: "富田林市",
  kishiwada: "岸和田市",
  izumiotsu: "泉大津市",
  izumisano: "泉佐野市",
  osaka_izumi: "和泉市",
  sennan: "泉南市",
  hannan: "阪南市",
  ikeda: "池田市",
  minoh: "箕面市",
  settsu: "摂津市",
  takaishi: "高石市",
  tadaoka: "忠岡町",
  kumatori: "熊取町",
  tajiri: "田尻町",
  misaki: "岬町",
  taishi: "太子町",
  kanan: "河南町",
  toyono: "豊能町",
  nose: "能勢町",
  chihayaakasaka: "千早赤阪村",
  osaka_sayama: "大阪狭山市",
  kaizuka: "貝塚市",
  tokyo: "東京都",
  yokohama: "横浜市",
  nagoya: "名古屋市",
  sapporo: "札幌市",
  fukuoka: "福岡市",
  kyoto: "京都市",
  kobe: "神戸市",
};

// 自治体IDから都道府県へのマッピング
const muniToPref: Record<string, string> = {
  // 大阪府
  osaka: "大阪府", osaka_pref: "大阪府", suita: "大阪府", toyonaka: "大阪府",
  sakai: "大阪府", higashiosaka: "大阪府", hirakata: "大阪府", takatsuki: "大阪府",
  ibaraki: "大阪府", yao: "大阪府", neyagawa: "大阪府", moriguchi: "大阪府",
  kadoma: "大阪府", daito: "大阪府", shijonawate: "大阪府", katano: "大阪府",
  kashiwara: "大阪府", matsubara: "大阪府", habikino: "大阪府", fujiidera: "大阪府",
  kawachinagano: "大阪府", tondabayashi: "大阪府", kishiwada: "大阪府",
  izumiotsu: "大阪府", izumisano: "大阪府", osaka_izumi: "大阪府",
  sennan: "大阪府", hannan: "大阪府", ikeda: "大阪府", minoh: "大阪府",
  settsu: "大阪府", takaishi: "大阪府", tadaoka: "大阪府", kumatori: "大阪府",
  tajiri: "大阪府", misaki: "大阪府", taishi: "大阪府", kanan: "大阪府",
  toyono: "大阪府", nose: "大阪府", chihayaakasaka: "大阪府",
  osaka_sayama: "大阪府", kaizuka: "大阪府",
  // 他の都道府県
  tokyo: "東京都",
  yokohama: "神奈川県",
  nagoya: "愛知県",
  sapporo: "北海道",
  fukuoka: "福岡県",
  kyoto: "京都府",
  kobe: "兵庫県",
};

// データに存在する都道府県のみ抽出（五十音順）
const municipalities = [...new Set(active.map((s) => s.data.municipality))];
const prefectures = [...new Set(municipalities.map((m) => muniToPref[m] ?? "その他"))].sort();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>自治体助成金まとめ | 最新の補助金・給付金情報</title>
    <meta name="description" content="全国の自治体が提供する補助金・助成金・給付金を分かりやすく紹介。子育て・介護・創業支援など。" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CNL0G50ECB"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CNL0G50ECB');
    </script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: "Hiragino Sans", "Meiryo", sans-serif; background: #f8f9fa; color: #333; line-height: 1.6; }
      header { background: #1a5276; color: white; padding: 1.5rem 1rem; text-align: center; }
      header h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
      header p { font-size: 0.9rem; opacity: 0.85; }
      .container { max-width: 960px; margin: 0 auto; padding: 1rem; }

      /* フィルターバー共通 */
      .filter-bar {
        background: white;
        border-radius: 8px;
        padding: 1rem;
        margin: 0.75rem 0;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
      }
      .filter-bar h2 {
        font-size: 0.8rem;
        font-weight: 600;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.6rem;
      }
      .filter-buttons { display: flex; flex-wrap: wrap; gap: 0.4rem; }

      /* 都道府県ボタン：やや大きめ */
      .pref-btn {
        padding: 0.35rem 1rem;
        border: 1.5px solid #bbb;
        border-radius: 20px;
        background: white;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.15s;
        color: #444;
      }
      .pref-btn:hover { border-color: #1a5276; color: #1a5276; }
      .pref-btn.active { background: #1a5276; color: white; border-color: #1a5276; }

      /* 自治体ボタン：コンパクト */
      .muni-btn {
        padding: 0.25rem 0.7rem;
        border: 1px solid #ccc;
        border-radius: 20px;
        background: white;
        cursor: pointer;
        font-size: 0.82rem;
        transition: all 0.15s;
        color: #555;
      }
      .muni-btn:hover { border-color: #1a5276; color: #1a5276; }
      .muni-btn.active { background: #2e86c1; color: white; border-color: #2e86c1; }

      /* タグボタン */
      .tag-btn {
        padding: 0.25rem 0.7rem;
        border: 1px solid #ccc;
        border-radius: 20px;
        background: white;
        cursor: pointer;
        font-size: 0.82rem;
        transition: all 0.15s;
        color: #555;
      }
      .tag-btn:hover { border-color: #1a5276; color: #1a5276; }
      .tag-btn.active { background: #1a5276; color: white; border-color: #1a5276; }

      /* 自治体バーの展開アニメーション */
      #muni-filter-bar {
        overflow: hidden;
        transition: max-height 0.25s ease, opacity 0.2s ease, margin 0.25s ease;
      }

      .count { color: #666; font-size: 0.85rem; margin: 0.25rem 0 0.75rem; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
      .card { background: white; border-radius: 8px; padding: 1rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); display: flex; flex-direction: column; gap: 0.5rem; }
      .card h3 { font-size: 0.95rem; line-height: 1.4; }
      .card h3 a { color: #1a5276; text-decoration: none; }
      .card h3 a:hover { text-decoration: underline; }
      .meta { font-size: 0.8rem; color: #666; display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .badge { padding: 0.15rem 0.5rem; border-radius: 4px; background: #e8f0fe; color: #1a5276; font-size: 0.75rem; }
      .deadline { color: #c0392b; font-weight: bold; }
      .amount { color: #27ae60; font-weight: bold; }
      footer { text-align: center; padding: 2rem; font-size: 0.8rem; color: #999; }
    </style>
  </head>
  <body>
    <header>
      <h1>自治体助成金まとめ</h1>
      <p>補助金・給付金・助成金を分かりやすく紹介</p>
    </header>

    <div class="container">

      <!-- ① 都道府県フィルター -->
      <div class="filter-bar">
        <h2>都道府県</h2>
        <div class="filter-buttons" id="pref-filters">
          <button class="pref-btn active" data-pref="all">すべて</button>
          {prefectures.map((p) => (
            <button class="pref-btn" data-pref={p}>{p}</button>
          ))}
        </div>
      </div>

      <!-- ② 自治体フィルター（都道府県選択後に展開） -->
      <div class="filter-bar" id="muni-filter-bar" style="display:none">
        <h2>自治体</h2>
        <div class="filter-buttons" id="muni-filters">
          <button class="muni-btn active" data-muni="all" data-pref="all">すべての自治体</button>
          {municipalities.map((m) => (
            <button
              class="muni-btn"
              data-muni={m}
              data-pref={muniToPref[m] ?? "その他"}
              style="display:none"
            >
              {muniLabel[m] ?? m}
            </button>
          ))}
        </div>
      </div>

      <!-- ③ タグフィルター -->
      <div class="filter-bar">
        <h2>カテゴリ <span style="font-size:0.75rem;color:#bbb;font-weight:normal">（複数選択可）</span></h2>
        <div class="filter-buttons" id="tag-filters">
          <button class="tag-btn active" data-tag="all">すべて</button>
          {allTags.map((t) => (
            <button class="tag-btn" data-tag={t}>{t}</button>
          ))}
        </div>
      </div>

      <p class="count" id="count">{active.length} 件</p>

      <div class="grid" id="card-grid">
        {active.map((s) => (
          <div
            class="card"
            data-muni={s.data.municipality}
            data-pref={muniToPref[s.data.municipality] ?? "その他"}
            data-tags={s.data.tags.join(",")}
          >
            <h3>
              <a href={`/subsidy/subsidies/${s.slug}`}>{s.data.title}</a>
            </h3>
            <div class="meta">
              {s.data.amount && <span class="amount">💴 {s.data.amount}</span>}
              {s.data.deadline && s.data.deadline !== "随時" && (
                <span class="deadline">⏰ {s.data.deadline}まで</span>
              )}
              {s.data.deadline === "随時" && <span>随時受付</span>}
            </div>
            <div class="meta">
              {s.data.tags.map((t) => <span class="badge">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    <footer>
    </footer>

    <script>
      const prefFilterBtns  = document.querySelectorAll<HTMLButtonElement>("#pref-filters [data-pref]");
      const muniFilterBar   = document.getElementById("muni-filter-bar")!;
      const muniFilterBtns  = document.querySelectorAll<HTMLButtonElement>("#muni-filters [data-muni]");
      const tagFilterBtns   = document.querySelectorAll<HTMLButtonElement>("#tag-filters [data-tag]");
      const cards           = document.querySelectorAll<HTMLElement>(".card");
      const countEl         = document.getElementById("count")!;

      let activePref = "all";
      let activeMuni = "all";
      let activeTags = new Set<string>();

      // ── 自治体バーの表示切り替え ───────────────────────────
      function updateMuniBar() {
        if (activePref === "all") {
          muniFilterBar.style.display = "none";
        } else {
          muniFilterBar.style.display = "";
          muniFilterBtns.forEach((btn) => {
            const muni = btn.dataset.muni!;
            const pref = btn.dataset.pref!;
            if (muni === "all") {
              btn.style.display = "";
              btn.classList.toggle("active", activeMuni === "all");
            } else {
              const visible = pref === activePref;
              btn.style.display = visible ? "" : "none";
              btn.classList.toggle("active", muni === activeMuni);
            }
          });
        }
      }

      // ── 利用可能タグの計算 ────────────────────────────────
      function getAvailableTags(): Set<string> | null {
        if (activeMuni !== "all") {
          const tags = new Set<string>();
          cards.forEach((c) => {
            if (c.dataset.muni === activeMuni)
              (c.dataset.tags || "").split(",").filter(Boolean).forEach((t) => tags.add(t));
          });
          return tags;
        }
        if (activePref !== "all") {
          const tags = new Set<string>();
          cards.forEach((c) => {
            if (c.dataset.pref === activePref)
              (c.dataset.tags || "").split(",").filter(Boolean).forEach((t) => tags.add(t));
          });
          return tags;
        }
        return null; // すべて表示
      }

      // ── タグボタンの同期 ──────────────────────────────────
      function syncTagButtons() {
        const available = getAvailableTags();
        // 使えなくなったタグを選択解除
        if (available !== null) {
          activeTags.forEach((t) => { if (!available.has(t)) activeTags.delete(t); });
        }
        tagFilterBtns.forEach((btn) => {
          const tag = btn.dataset.tag!;
          if (tag === "all") {
            btn.classList.toggle("active", activeTags.size === 0);
            btn.style.display = "";
          } else {
            const shown = available === null || available.has(tag);
            btn.style.display = shown ? "" : "none";
            btn.classList.toggle("active", activeTags.has(tag));
          }
        });
      }

      // ── カード表示の更新 ──────────────────────────────────
      function updateDisplay() {
        let visible = 0;
        cards.forEach((card) => {
          const pref = card.dataset.pref!;
          const muni = card.dataset.muni!;
          const tags = (card.dataset.tags || "").split(",");
          const prefOk = activePref === "all" || pref === activePref;
          const muniOk = activeMuni === "all" || muni === activeMuni;
          const tagOk  = activeTags.size === 0 || [...activeTags].every((t) => tags.includes(t));
          const show   = prefOk && muniOk && tagOk;
          card.style.display = show ? "" : "none";
          if (show) visible++;
        });
        countEl.textContent = `${visible} 件`;
      }

      // ── 都道府県ボタンのクリック ──────────────────────────
      prefFilterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          activePref = btn.dataset.pref!;
          activeMuni = "all";
          prefFilterBtns.forEach((b) => b.classList.toggle("active", b.dataset.pref === activePref));
          updateMuniBar();
          syncTagButtons();
          updateDisplay();
        });
      });

      // ── 自治体ボタンのクリック ────────────────────────────
      muniFilterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          activeMuni = btn.dataset.muni!;
          updateMuniBar();
          syncTagButtons();
          updateDisplay();
        });
      });

      // ── タグボタンのクリック ──────────────────────────────
      tagFilterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const tag = btn.dataset.tag!;
          if (tag === "all") {
            activeTags.clear();
          } else {
            activeTags.has(tag) ? activeTags.delete(tag) : activeTags.add(tag);
          }
          syncTagButtons();
          updateDisplay();
        });
      });

      // ── URLパラメータから初期フィルタを復元 ──────────────
      const urlParams = new URLSearchParams(window.location.search);
      const muniParam = urlParams.get("muni");
      if (muniParam) {
        const muniBtn = document.querySelector<HTMLButtonElement>(`#muni-filters [data-muni="${muniParam}"]`);
        if (muniBtn) {
          // 1) まず都道府県を選択
          const prefName = muniBtn.dataset.pref!;
          const prefBtn = document.querySelector<HTMLButtonElement>(`#pref-filters [data-pref="${prefName}"]`);
          if (prefBtn) prefBtn.click();
          // 2) 次に自治体を選択
          muniBtn.click();
        }
      }
    </script>
  </body>
</html>
